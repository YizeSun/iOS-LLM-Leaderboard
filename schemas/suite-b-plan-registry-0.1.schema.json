{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/YizeSun/iOS-LLM-Leaderboard/schemas/suite-b-plan-registry-0.1.schema.json",
  "title": "Suite B Workload Plan Registry 0.1",
  "type": "object",
  "required": ["schema_version", "plans"],
  "properties": {
    "schema_version": { "const": "suite-b-plan-registry-0.1" },
    "plans": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "required": ["plan_id", "plan_version", "workload_id", "workload_version", "category", "runner_kind", "thinking_mode", "user_visible_ttft_available", "warmup_runs", "measured_runs", "output_token_limit", "target_input_tokens", "fixture_sha256"],
        "properties": {
          "plan_id": { "type": "string", "minLength": 1 },
          "plan_version": { "type": "string", "minLength": 1 },
          "workload_id": { "type": "string", "minLength": 1 },
          "workload_version": { "type": "string", "minLength": 1 },
          "category": { "enum": ["pipeline", "user-experience"] },
          "runner_kind": { "enum": ["single-session", "token-exact-point-series", "token-exact-point-series-with-quality"] },
          "thinking_mode": { "type": "string", "minLength": 1 },
          "user_visible_ttft_available": { "type": "boolean" },
          "warmup_runs": { "type": "integer", "minimum": 0 },
          "measured_runs": { "type": "integer", "minimum": 1 },
          "output_token_limit": { "type": "integer", "minimum": 1 },
          "target_input_tokens": { "type": "array", "items": { "type": "integer", "minimum": 1 } },
          "fixture_sha256": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^[a-f0-9]{64}$" } }
        }
      }
    }
  }
}
