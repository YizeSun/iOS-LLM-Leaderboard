{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/YizeSun/iOS-LLM-Leaderboard/schemas/suite-b-pilot-bundle-0.4.schema.json",
  "title": "Suite B Pilot Result Bundle 0.4",
  "description": "Non-official physical-iPhone pilot with explicit workload, boundary, generation, dependency, and power evidence.",
  "type": "object",
  "required": [
    "schemaVersion",
    "resultID",
    "createdAt",
    "officialResultEligible",
    "plan",
    "workload",
    "measurementMode",
    "generationConfiguration",
    "model",
    "runtime",
    "device",
    "eligibility",
    "summary",
    "attempts"
  ],
  "properties": {
    "schemaVersion": { "const": "suite-b-pilot-bundle-0.4" },
    "resultID": { "type": "string", "minLength": 8 },
    "createdAt": { "type": "string", "format": "date-time" },
    "officialResultEligible": { "const": false },
    "plan": {
      "type": "object",
      "required": ["id", "version", "promptSHA256", "warmupRuns", "measuredRuns", "outputTokenLimit", "v2ProfileMapping"],
      "properties": {
        "id": { "const": "suite-b-pilot-001" },
        "version": { "type": "string" },
        "promptSHA256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "warmupRuns": { "const": 1 },
        "measuredRuns": { "const": 5 },
        "outputTokenLimit": { "type": "integer", "minimum": 1 },
        "v2ProfileMapping": { "type": "string", "minLength": 1 }
      }
    },
    "workload": {
      "type": "object",
      "required": ["id", "version", "category", "promptSHA256"],
      "properties": {
        "category": { "enum": ["user-experience", "pipeline"] },
        "promptSHA256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
      }
    },
    "measurementMode": {
      "type": "object",
      "required": ["id", "timingBoundaryVersion", "pipelineTTFTStart", "pipelineTTFTEnd", "userVisibleTTFTAvailable", "prefillSource", "decodeFormula", "memoryMetric", "memorySamplingIntervalMilliseconds"]
    },
    "generationConfiguration": {
      "type": "object",
      "required": ["samplingEnabled", "temperature", "thinkingMode", "chatTemplateIdentity", "includeStopTokenInRawEvents", "outputTokenLimit", "contextPolicy", "modelLoadPolicy", "kvCachePolicy"]
    },
    "model": {
      "type": "object",
      "required": ["displayName", "baseModelID", "artifactID", "artifactRevision", "quantization", "modelFormat", "artifactContentHash"]
    },
    "runtime": {
      "type": "object",
      "required": ["name", "version", "resolvedRevision", "backend", "mlxSwiftVersion", "mlxSwiftRevision", "downloaderPackage", "tokenizerPackage"]
    },
    "device": {
      "type": "object",
      "required": ["displayName", "machineIdentifier", "systemName", "systemVersion", "systemBuild", "debuggerAttached", "buildConfiguration", "appVersion", "appBuild", "appSourceCommit", "lowPowerModeEnabled", "batteryLevelPercent", "batteryState"],
      "properties": {
        "debuggerAttached": { "type": "boolean" },
        "appSourceCommit": { "type": ["string", "null"] },
        "lowPowerModeEnabled": { "type": "boolean" },
        "batteryLevelPercent": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
        "batteryState": { "enum": ["unknown", "unplugged", "charging", "full"] }
      }
    },
    "eligibility": {
      "type": "object",
      "required": ["sessionValidity", "coldPerformance", "sustainedPerformance", "thermalStability", "officialLeaderboard"]
    },
    "summary": {
      "type": "object",
      "required": ["successfulMeasuredRuns", "failedMeasuredRuns", "finalThermalState", "degradation"]
    },
    "attempts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["runIndex", "role", "outcome", "thermalStateBefore", "thermalStateAfter", "memorySamplingIntervalMilliseconds", "metrics", "tokenEvents"]
      }
    }
  }
}
